\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Results on the harder task suite (7.3\% keyword cues). Interference \emph  {significantly improves} accuracy ($p = 0.023$), reversing the direction from the original tasks.}}{5}{table.caption.18}\protected@file@percent }
\newlabel{tab:harder}{{6}{5}{Results on the harder task suite (7.3\% keyword cues). Interference \emph {significantly improves} accuracy ($p = 0.023$), reversing the direction from the original tasks}{table.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Left: Original tasks (88.8\% keyword cues) show no significant interference effect. Right: Harder tasks (7.3\% keyword cues) show interference \emph  {significantly improving} accuracy ($p = 0.023$). Error bars omitted for clarity; see Table~\ref {tab:harder} for exact values.}}{5}{figure.caption.19}\protected@file@percent }
\newlabel{fig:harder}{{5}{5}{Left: Original tasks (88.8\% keyword cues) show no significant interference effect. Right: Harder tasks (7.3\% keyword cues) show interference \emph {significantly improving} accuracy ($p = 0.023$). Error bars omitted for clarity; see Table~\ref {tab:harder} for exact values}{figure.caption.19}{}}
